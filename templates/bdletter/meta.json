  "description": "A LaTeX class for writing authentic Bangladeshi official letters. Supports government offices, schools, colleges, banks, NGOs, and general public use. Follows the standard Bangladeshi formal letter structure with বরাবর, বিষয়, and বিনীত নিবেদক blocks. Noto Serif Bengali font is bundled — no installation required.",
  "compatibleWith": [
    "tectonic",
    "xelatex"
  ],
  "fonts": {
    "primary": "Noto Serif Bengali",
    "source": "https://fonts.google.com/noto/specimen/Noto+Serif+Bengali"
  },
  "packages": [
    "fontspec",
    "polyglossia",
    "geometry",
    "setspace",
    "parskip",
    "etoolbox",
    "keyval"
  ],
